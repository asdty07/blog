<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
"http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="com.blog.blog.dao.BlogDao">

	<select id="getSecurityPw" parameterType="String" resultType="String">
		select u_pw from user where u_id = #{id};
	</select>

	<select id="getUserInfo" resultType="UserDto">
		select u_name from user where u_id = #{id};
	</select>
</mapper>